# Python Processing Service Environment Variables

# Service
HOST=0.0.0.0
PORT=8000

# NestJS Backend callback URL
NESTJS_BACKEND_URL=http://localhost:3000/api

# Google Gemini API Key
AI_API_KEY=your-google-gemini-api-key
AI_MODEL=gemini-3.1-flash-lite-preview

# Database
DATABASE_URL=postgresql://postgres:0000@localhost:5432/crm_db
